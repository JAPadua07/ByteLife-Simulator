 // Inherit the parent event
event_inherited();

dialog.add(ProfKei, "Hello class!, I am Mr. Keiting. Today, we are going to learn about the parts of a computer");
dialog.add(BgAva1, "Hello Mr. Keiting! I just want to ask, are we going to learn about the 'brain' of the computer today?");
dialog.add(ProfKei, "Yes! You're right baout that, today we are going to learn about the 'CPU' or the 'CENTRAL PROCESSING UNIT'.");
dialog.add(ProfKei, "But of course, the brain wouldn't be able to function without the other parts so we will discuss about them as well.");
dialog.add(ProfKei, "First up is the motherboard. Think of it as the city hall of the Computer")
dialog.add(ProfKei, "The motherboard houses various parts of the Computer System that we use such as the CPU, Memory, and Ram.")
dialog.add(ProfKei, "The motherboard also distributes the electricity and the information that runs through the system.")
dialog.add(BgAva2, "But why do we need the motherboard? Can't everything just run through the CPU if that is the case?")
dialog.add(ProfKei, "Great question! In some devices such as smartphones, those do happen to use a System-on-Chip or SoC.")
dialog.add(ProfKei, "They are used for small form factor devices but for a personal computer? No, they wouldn't work at all.")
dialog.add(ProfKei, "Meet the CPU, of course we are all familiar now with the CPU. As mentioned earlier, it is called the brain of the System")
dialog.add(ProfKei, "CPU handles the arithmetic, logic, and controls the flow of data.")
